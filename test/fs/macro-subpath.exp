	-re "Child process initialized in \[0-9\]+.\[0-9\]+ ms"
}
expect {
	timeout {puts "TESTING ERROR 2.1 Pictures\n";exit}
	"Permission denied" {}
	-re {ret 0} {puts "TESTING ERROR 2.2 Pictures\n";exit}
}
