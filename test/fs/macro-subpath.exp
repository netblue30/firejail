	timeout {puts "TESTING ERROR 2 Videos\n";exit}
	-re "Child process initialized in \[0-9\]+.\[0-9\]+ ms"
}
expect {
	timeout {puts "TESTING ERROR 2.1 Videos\n";exit}
	"Permission denied" {}
	-re {ret 0} {puts "TESTING ERROR 2.2 Videos\n";exit}
}
